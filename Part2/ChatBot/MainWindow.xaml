<Window x:Class="ChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatBot"
        mc:Ignorable="d"
        Title="Cybersecurity ChatBot"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <!-- Main Border -->
        <Border Width="820"
                Height="520"
                CornerRadius="20"
                Background="Black"
                Padding="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="DarkViolet"
                        CornerRadius="15"
                        Padding="1">

                    <StackPanel Orientation="Horizontal">

                        <!-- Bot Icon -->
                        <Border Width="45"
                                Height="45"
                                CornerRadius="22"
                                Background="White">
                            <TextBlock Text="🤖"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,9,0,0" Width="33"/>
                        </Border>

                        <StackPanel Margin="15,0,0,0">

                            <TextBlock Text="    Cybersecurity Application Awareness "
                                       Foreground="White"
                                       FontSize="22"
                                       
                                       FontWeight="Bold" Width="460"/>

                            <TextBlock Text="    Online"
                                       Foreground="#D1FAE5"
                                       FontSize="20" Height="24"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Chat Area -->
                <Border Grid.Row="1"
                        Margin="0,15,0,15"
                        Background="#F8FAFC"
                        CornerRadius="15">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <ListBox Name="Listchat"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Padding="10">

                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="5"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </ListBox.Resources>

                        </ListBox>
                    </ScrollViewer>
                </Border>

                <!-- Bottom Input Area -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Message Textbox -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="15"
                            Margin="0,0,10,0">

                        <TextBox Name="txtMessage"
                                 BorderThickness="0"
                                 FontSize="16"
                                 Padding="15"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Foreground="#1E293B"
                                 Text=""/>
                    </Border>

                    <!-- Send Button -->
                    <Button Name="btnSend"
                            Grid.Column="1"
                            Content="Send"
                            Click="OnButtonClick"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="DarkViolet"
                            BorderThickness="0"
                            Margin="0,0,10,0"
                            Cursor="Hand">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Clear Button -->
                    <Button Name="btnClear"
                            Grid.Column="2"
                            Content="Clear"
                            Click="ClearButtonClick"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="#EF4444"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>